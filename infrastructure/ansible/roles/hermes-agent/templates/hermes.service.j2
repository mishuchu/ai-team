[Unit]
Description=Hermes AI Agent - {{ agent_name }}
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hermes
Group=hermes
WorkingDirectory=/opt/hermes
Environment="PATH=/opt/hermes/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin"
Environment="PYTHONPATH=/opt/hermes"
ExecStart=/opt/hermes/venv/bin/python3 -m hermes_agent --config /opt/hermes/config.yaml
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/opt/hermes/storage

[Install]
WantedBy=multi-user.target